# ════════════════════════════════════════════════════════════════════════════
#  QUDE — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                        # development | production | test
APP_NAME=Qude
APP_URL=http://localhost:5000               # Public URL of the backend API

# ── Backend Server ───────────────────────────────────────────────────────────
PORT=5000
API_PREFIX=/api

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost                     # Use 'postgres' inside Docker
POSTGRES_PORT=5432
POSTGRES_DB=qude
POSTGRES_USER=qude_user
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://qude_user:change_me_strong_password@localhost:5432/qude

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost                        # Use 'redis' inside Docker
REDIS_PORT=6379
REDIS_PASSWORD=                            # Leave blank if no auth in dev
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5                         # Max wrong attempts before lockout
OTP_RATE_LIMIT_WINDOW_MINUTES=10
OTP_RATE_LIMIT_MAX=5                       # Max OTPs per phone per window

# ── Twilio (SMS) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx           # Your Twilio sender number

# ── WhatsApp (Twilio WhatsApp Sandbox or BSP) ─────────────────────────────────
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886 # Twilio sandbox number
# For production WhatsApp Business API (replace Twilio with direct BSP):
# WHATSAPP_BSP=twilio                      # twilio | gupshup | wati | 360dialog
# WHATSAPP_API_KEY=
# WHATSAPP_PHONE_NUMBER_ID=

# ── Notifications ────────────────────────────────────────────────────────────
NOTIFY_AHEAD_COUNT=10                      # Alert devotee when N tokens ahead
NOTIFY_CHANNEL=both                        # sms | whatsapp | both
NOTIFICATION_RETRY_ATTEMPTS=3

# ── QR Code ──────────────────────────────────────────────────────────────────
QR_BASE_URL=http://localhost:5000          # Used to build entrance QR payload
QR_IMAGE_WIDTH=300
QR_ERROR_CORRECTION=M                      # L | M | Q | H

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3002
# Production: CORS_ORIGINS=https://admin.qude.app,https://gate.qude.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000               # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ── Admin Dashboard (Vite) ───────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_APP_NAME=Qude Admin

# ── Gate Scanner (Vite) ──────────────────────────────────────────────────────
# (uses same VITE_API_URL and VITE_SOCKET_URL — set per app in their own .env)

# ── Mobile App (Expo) ────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://192.168.1.x:5000/api   # Your machine's LAN IP
EXPO_PUBLIC_SOCKET_URL=http://192.168.1.x:5000
EXPO_PUBLIC_APP_NAME=Qude

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug                            # error | warn | info | debug
LOG_FORMAT=dev                             # dev | combined | json

# ── Token Settings ───────────────────────────────────────────────────────────
TOKEN_EXPIRY_HOURS=24                      # Token auto-expires after this
TOKEN_QR_EXPIRY_MINUTES=30                 # QR validity window at the gate
MAX_ACTIVE_TOKENS_PER_USER=1              # Prevent duplicate joins

# ── Queue Defaults ───────────────────────────────────────────────────────────
DEFAULT_AVG_WAIT_MINUTES=5                 # Per-token average, used for estimates
DEFAULT_SLOT_SIZE=1                        # Tokens called per advance
DEFAULT_MAX_CAPACITY=500                   # Per queue

# ── File Upload (future) ──────────────────────────────────────────────────────
# UPLOAD_MAX_SIZE_MB=5
# UPLOAD_ALLOWED_TYPES=image/jpeg,image/png

# ── Email (future — admin alerts, reports) ────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@qude.app
# SMTP_PASS=
# EMAIL_FROM=Qude <noreply@qude.app>

# ── Monitoring (future) ───────────────────────────────────────────────────────
# SENTRY_DSN=
# NEW_RELIC_KEY=
